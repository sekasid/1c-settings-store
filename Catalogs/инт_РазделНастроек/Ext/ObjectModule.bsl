///////////////////////////////////////////////////////////////////////////////////////////////////////
// Модуль объекта справочника инт_РазделНастроек.
// Разделы настроек используются как программные ключи записей регистра инт_НастройкиСистемы.
///////////////////////////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытий

// Проверяет уникальность наименования — оно служит программным ключом настройки.
//
Процедура ПередЗаписью(Отказ)
	
	Если ОбменДанными.Загрузка Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Наименование) Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Разделы.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.инт_РазделНастроек КАК Разделы
	|ГДЕ
	|	Разделы.Наименование = &Наименование
	|	И Разделы.Ссылка <> &Ссылка
	|	И НЕ Разделы.ПометкаУдаления";
	Запрос.УстановитьПараметр("Наименование", Наименование);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Если Не Запрос.Выполнить().Пустой() Тогда
		
		Отказ = Истина;
		
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Раздел настроек с наименованием «" + Наименование + "» уже существует.";
		Сообщение.Поле = "Наименование";
		Сообщение.УстановитьДанные(ЭтотОбъект);
		Сообщение.Сообщить();
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
