///////////////////////////////////////////////////////////////////////////////////////////////////////
// Модуль формы списка регистра сведений инт_НастройкиСистемы.
///////////////////////////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

// Инициализация формы списка.
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Открывает текстовое представление содержимого хранилища значений текущей записи.
//
&НаКлиенте
Процедура ПоказатьСодержимое(Команда)
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	РезультатПросмотра = ПолучитьТекстСодержимогоНаСервере(ТекущиеДанные.РазделНастроек);
	
	Если Не РезультатПросмотра.Успех Тогда
		
		ПоказатьПредупреждение(, РезультатПросмотра.Текст);
		Возврат;
		
	КонецЕсли;
	
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.УстановитьТекст(РезультатПросмотра.Текст);
	ТекстовыйДокумент.Показать(РезультатПросмотра.Заголовок);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Формирует текстовое представление содержимого хранилища настройки.
//
// Параметры:
//  РазделНастроек - СправочникСсылка.инт_РазделНастроек - раздел настроек.
//
// Возвращаемое значение:
//  Структура - результат просмотра (Успех, Текст, Заголовок).
//
&НаСервереБезКонтекста
Функция ПолучитьТекстСодержимогоНаСервере(РазделНастроек)
	
	Возврат РегистрыСведений.инт_НастройкиСистемы.ПолучитьТекстСодержимогоХранилища(РазделНастроек);
	
КонецФункции

#КонецОбласти
