///////////////////////////////////////////////////////////////////////////////////////////////////////
// Модуль формы записи регистра сведений инт_НастройкиСистемы.
///////////////////////////////////////////////////////////////////////////////////////////////////////

#Область ОбработчикиСобытийФормы

// Инициализация формы записи.
//
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ОбновитьСостояниеХранилищаНаСервере();
	
КонецПроцедуры

// После чтения записи обновляет состояние просмотра хранилища.
//
&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ОбновитьСостояниеХранилищаНаСервере();
	
КонецПроцедуры

// После записи обновляет состояние просмотра хранилища.
//
&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	ОбновитьСостояниеХранилищаНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// При смене раздела настроек обновляет состояние просмотра хранилища.
//
&НаКлиенте
Процедура РазделНастроекПриИзменении(Элемент)
	
	ОбновитьСостояниеХранилищаНаСервере();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Открывает текстовое представление содержимого хранилища значений записи.
//
&НаКлиенте
Процедура ПоказатьСодержимое(Команда)
	
	РезультатПросмотра = ПолучитьТекстСодержимогоТекущейЗаписиНаСервере();
	
	Если Не РезультатПросмотра.Успех Тогда
		
		ПоказатьПредупреждение(, РезультатПросмотра.Текст);
		Возврат;
		
	КонецЕсли;
	
	ТекстовыйДокумент = Новый ТекстовыйДокумент;
	ТекстовыйДокумент.УстановитьТекст(РезультатПросмотра.Текст);
	ТекстовыйДокумент.Показать(РезультатПросмотра.Заголовок);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Обновляет доступность команды и надпись о наличии данных в хранилище.
//
&НаСервере
Процедура ОбновитьСостояниеХранилищаНаСервере()
	
	ЕстьСодержимое = ЕстьСодержимоеВТекущейЗаписи();
	Элементы.ФормаПоказатьСодержимое.Доступность = ЕстьСодержимое;
	
	Если ЕстьСодержимое Тогда
		
		Элементы.НадписьХранилищеЗначений.Заголовок = "Хранилище значений: есть данные (кнопка «Показать содержимое»)";
		
	Иначе
		
		Элементы.НадписьХранилищеЗначений.Заголовок = "Хранилище значений: нет данных";
		
	КонецЕсли;
	
КонецПроцедуры

// Проверяет наличие значения в хранилище текущей записи формы.
//
// Возвращаемое значение:
//  Булево - Истина, если хранилище заполнено.
//
&НаСервере
Функция ЕстьСодержимоеВТекущейЗаписи()
	
	Если ТипЗнч(Запись.ЗначениеХранилище) = Тип("ХранилищеЗначения") Тогда
		
		Если Запись.ЗначениеХранилище.Получить() <> Неопределено Тогда
			
			Возврат Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РегистрыСведений.инт_НастройкиСистемы.ЕстьСодержимоеХранилища(Запись.РазделНастроек);
	
КонецФункции

// Формирует текстовое представление содержимого хранилища текущей записи.
//
// Возвращаемое значение:
//  Структура - результат просмотра (Успех, Текст, Заголовок).
//
&НаСервере
Функция ПолучитьТекстСодержимогоТекущейЗаписиНаСервере()
	
	Если ТипЗнч(Запись.ЗначениеХранилище) = Тип("ХранилищеЗначения") Тогда
		
		ИзвлеченноеЗначение = Запись.ЗначениеХранилище.Получить();
		
		Если ИзвлеченноеЗначение <> Неопределено Тогда
			
			Результат = Новый Структура("Успех, Текст, Заголовок", Истина, "", "");
			Результат.Заголовок = "Содержимое настройки: " + Строка(Запись.РазделНастроек);
			Результат.Текст = РегистрыСведений.инт_НастройкиСистемы.СформироватьПредставлениеЗначения(ИзвлеченноеЗначение);
			Возврат Результат;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат РегистрыСведений.инт_НастройкиСистемы.ПолучитьТекстСодержимогоХранилища(Запись.РазделНастроек);
	
КонецФункции

#КонецОбласти
