
// Записывает настройку как запись регистра
// Параметры - СтруктураНастройки - тип структура - имена ключей должны совпадать со именами полей регистра
//             значения должны соответствовать по типу полям регистра
//             Обязательные ключи - имена измерений регистра
// Возвращаемое значение истина если запись удалась, ложь - если запись не удалась
//
Функция ЗаписатьНастройкуСистемы(СтруктураНастройки) Экспорт	
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		Запись = РегистрыСведений.инт_НастройкиСистемы.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, СтруктураНастройки);                   
		Запись.Записать();
		ОбновитьПовторноИспользуемыеЗначения();
		Возврат Истина;
	Исключение
		ЗаписьЖурналаРегистрации("Ошибка записи настройки системы", УровеньЖурналаРегистрации.Ошибка,,, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

// Получает значения настройки из запись регистра
// Параметры 
//  ПараметрыПолучения - Структура - Управляет поведением функции, смотрите код.
//     Обязательные ключи:
//		РазделНастроек - Строка, СправочникСсылка.инт_РазделНастроек - Передается имя элемента справочника или ссылка
//		ПолучитьЗначение - Булево - Истина, возвращает данные "Значение"
//		ПолучитьЗначениеХранилище - Булево - Истина, возвращает данные "ЗначениеСтрокаНеограниченная"
//		ПолучитьЗначениеСтрокаНеограниченная - Булево - Истина, возвращает данные "ПолучитьЗначениеСтрокаНеограниченная"
// Возвращаемое значение 
//	- Структура - Если нужно получить более одного значения
//  - Значение - Требуется получить только одно из значений
//  - NULL - Ошибка получения настроек
//
Функция ПолучитьНастройкуСистемы(ПараметрыПолучения) Экспорт 
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ПараметрыПолучения.Свойство("РазделНастроек") = Ложь Тогда
		Возврат NULL; // Тот кто вызвал сам не знает что он хочет.
	КонецЕсли;
	
	РазделНастроекСсылка = Неопределено;
	Если ТипЗнч(ПараметрыПолучения.РазделНастроек) = Тип("Строка") Тогда
		РазделНастроекСсылка = ПолучитьРазделНастроекПоИмени(ПараметрыПолучения.РазделНастроек);
	Иначе
		РазделНастроекСсылка = ПараметрыПолучения.РазделНастроек; 
	КонецЕсли;
	
	Если не ТипЗнч(РазделНастроекСсылка) = Тип("СправочникСсылка.инт_РазделНастроек") Тогда
		Возврат NULL;
	КонецЕсли;
	
	ПолучитьЗнч1  = ПараметрыПолучения.Свойство("ПолучитьЗначение") и ПараметрыПолучения.ПолучитьЗначение = Истина;
	ПолучитьЗнч2  = ПараметрыПолучения.Свойство("ПолучитьЗначениеХранилище") и ПараметрыПолучения.ПолучитьЗначениеХранилище = Истина;
	ПолучитьЗнч3  = ПараметрыПолучения.Свойство("ПолучитьЗначениеСтрокаНеограниченная") и ПараметрыПолучения.ПолучитьЗначениеСтрокаНеограниченная = Истина;
    ЗапятаяПоля1  = ?(ПолучитьЗнч1 и (ПолучитьЗнч2 или ПолучитьЗнч3), ",", "");
	ЗапятаяПоля2  = ?(ПолучитьЗнч2 и ПолучитьЗнч3 , ",", "");
	ПолеЗапроса1  = ?(ПолучитьЗнч1, "РС.Значение КАК Знч1", "");
	ПолеЗапроса2  = ?(ПолучитьЗнч2, "РС.ЗначениеХранилище КАК Знч2", "");
	ПолеЗапроса3  = ?(ПолучитьЗнч3, "РС.ЗначениеСтрокаНеограниченная КАК Знч3", "");
	
	КонтрольнаяСумма = ПолучитьЗнч1 + ПолучитьЗнч2 + ПолучитьЗнч3;
    Если КонтрольнаяСумма = 0 Тогда
		Возврат NULL; // Тот кто вызвал сам не знает что он хочет.
	КонецЕсли;
	
	Если КонтрольнаяСумма = 1 Тогда
		РезультатСтруктура  = Новый Структура;
	Иначе
		РезультатСтруктура = Новый Структура(?(ПолучитьЗнч1, "Значение", "") + ЗапятаяПоля1 + 
		                           ?(ПолучитьЗнч2, "ЗначениеХранилище", "")  + ЗапятаяПоля2 + 
								   ?(ПолучитьЗнч3, "ЗначениеСтрокаНеограниченная", ""));
	КонецЕсли;
	   	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ " + ПолеЗапроса1 + ЗапятаяПоля1 + ПолеЗапроса2 + ЗапятаяПоля2 + ПолеЗапроса3 + "
	|ИЗ
	|	РегистрСведений.инт_НастройкиСистемы КАК РС
	|ГДЕ
	|	РС.РазделНастроек = &РазделНастроек";
	Запрос.УстановитьПараметр("РазделНастроек", РазделНастроекСсылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат NULL;
	КонецЕсли;

	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Если ПолучитьЗнч1 Тогда		
		Если КонтрольнаяСумма = 1 Тогда
			Возврат Выборка.Знч1;
		КонецЕсли;		
		РезультатСтруктура.Значение = Выборка.Знч1;		
	КонецЕсли;                            
	
	Если ПолучитьЗнч2 Тогда
		
		Если ТипЗнч(Выборка.Знч2) = Тип("ХранилищеЗначения")  Тогда
			Знч = Выборка.Знч2.Получить();
		Иначе
			Знч = Выборка.Знч2;
		КонецЕсли;
		
		Если КонтрольнаяСумма = 1 Тогда
			Возврат Знч;
		КонецЕсли;
		
		РезультатСтруктура.ЗначениеХранилище = Знч;
		
	КонецЕсли;
	
	Если ПолучитьЗнч3 Тогда
		
		Знч = Выборка.Знч3;
		ПреобразоватьИзСтрокиВнутрЗнч3 = ПараметрыПолучения.Свойство("ПреобразоватьИзСтрокиВнутрСтрокаНеограниченная") и ПараметрыПолучения.ПреобразоватьИзСтрокиВнутрСтрокаНеограниченная = Истина;
		Если ПреобразоватьИзСтрокиВнутрЗнч3 Тогда			
			Попытка 
				Знч = ЗначениеИзСтрокиВнутр(Знч);
			Исключение
				// В случае не удачи вернется то что получена из запроса пусть с этим разбираются там откуда вызвали
			КонецПопытки;			
		КонецЕсли;		
		
		Если КонтрольнаяСумма = 1 Тогда
			Возврат Знч;
		КонецЕсли; 
		
		РезультатСтруктура.ЗначениеСтрокаНеограниченная = Знч;
		
	КонецЕсли;
	
	Возврат РезультатСтруктура;
	
КонецФункции

// Получает ссылку на элемент справочника инт_РазделНастроек
//
// Параметры - Имя          - тип строка - поле поиска по реквизиту справочника "Имя";
//             Наименование - тип строка - наименование элемента справочника, имеет смысл передавать если третий параметра Истина
//             СоздатьНовый - тип булево - признак того что нужно создать новый элемент справочника, если он не найден по первому параметру
//
// Возвращаемое значение - ссылка справочника инт_РазделНастроек
//
Функция ПолучитьРазделНастроекПоИмени(Имя, Наименование = "", СоздатьНовый = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если не ЗначениеЗаполнено(Имя) Тогда
		Возврат Справочники.инт_РазделНастроек.ПустаяСсылка();
	КонецЕсли;
	
	Если не ТипЗнч(Имя) = Тип("Строка") Тогда
		Возврат Справочники.инт_РазделНастроек.ПустаяСсылка();
	КонецЕсли;
	
	РазделНастроекСсылка = Справочники.инт_РазделНастроек.НайтиПоНаименованию(Имя, Истина);
	Если ЗначениеЗаполнено(РазделНастроекСсылка) или не СоздатьНовый = Истина Тогда
		Возврат РазделНастроекСсылка;
	КонецЕсли;
	
	СпрОбъект = Справочники.инт_РазделНастроек.СоздатьЭлемент();
	СпрОбъект.Наименование = Имя;
	СпрОбъект.ОбменДанными.Загрузка = Истина;
	СпрОбъект.Записать();
	
	Возврат СпрОбъект.Ссылка;
	
КонецФункции

// Проверяет, есть ли в записи непустое значение ресурса ЗначениеХранилище.
//
// Параметры:
//  РазделНастроек - СправочникСсылка.инт_РазделНастроек - раздел настроек.
//
// Возвращаемое значение:
//  Булево - Истина, если в хранилище есть извлечённое значение.
//
Функция ЕстьСодержимоеХранилища(РазделНастроек) Экспорт
	
	Если Не ЗначениеЗаполнено(РазделНастроек) Тогда
		
		Возврат Ложь;
		
	КонецЕсли;
	
	ПараметрыПолучения = Новый Структура;
	ПараметрыПолучения.Вставить("РазделНастроек", РазделНастроек);
	ПараметрыПолучения.Вставить("ПолучитьЗначениеХранилище", Истина);
	
	ЗначениеИзХранилища = ПолучитьНастройкуСистемы(ПараметрыПолучения);
	
	Возврат ЗначениеИзХранилища <> NULL И ЗначениеИзХранилища <> Неопределено;
	
КонецФункции

// Формирует текстовое представление содержимого хранилища значений настройки.
//
// Параметры:
//  РазделНастроек - СправочникСсылка.инт_РазделНастроек - раздел настроек.
//
// Возвращаемое значение:
//  Структура:
//    * Успех - Булево - удалось ли получить содержимое;
//    * Текст - Строка - представление или сообщение об ошибке;
//    * Заголовок - Строка - заголовок окна просмотра.
//
Функция ПолучитьТекстСодержимогоХранилища(РазделНастроек) Экспорт
	
	Результат = Новый Структура("Успех, Текст, Заголовок", Ложь, "", "");
	
	Если Не ЗначениеЗаполнено(РазделНастроек) Тогда
		
		Результат.Текст = "Не указан раздел настроек.";
		Возврат Результат;
		
	КонецЕсли;
	
	ПараметрыПолучения = Новый Структура;
	ПараметрыПолучения.Вставить("РазделНастроек", РазделНастроек);
	ПараметрыПолучения.Вставить("ПолучитьЗначениеХранилище", Истина);
	
	ЗначениеИзХранилища = ПолучитьНастройкуСистемы(ПараметрыПолучения);
	
	Если ЗначениеИзХранилища = NULL Тогда
		
		Результат.Текст = "Запись настройки не найдена.";
		Возврат Результат;
		
	КонецЕсли;
	
	Если ЗначениеИзХранилища = Неопределено Тогда
		
		Результат.Текст = "В хранилище значений нет данных.";
		Возврат Результат;
		
	КонецЕсли;
	
	Результат.Успех = Истина;
	Результат.Заголовок = "Содержимое настройки: " + Строка(РазделНастроек);
	Результат.Текст = СформироватьПредставлениеЗначения(ЗначениеИзХранилища);
	
	Возврат Результат;
	
КонецФункции

// Строит читаемое текстовое представление произвольного значения.
//
// Параметры:
//  Значение - Произвольный - значение из хранилища;
//  Уровень - Число - уровень вложенности для отступа.
//
// Возвращаемое значение:
//  Строка - текстовое представление.
//
Функция СформироватьПредставлениеЗначения(Значение, Уровень = 0) Экспорт
	
	Префикс = "";
	
	Для Счетчик = 1 По Уровень Цикл
		
		Префикс = Префикс + "  ";
		
	КонецЦикла;
	
	ТипЗначения = ТипЗнч(Значение);
	
	Если Значение = Неопределено Тогда
		
		Возврат Префикс + "<Неопределено>";
		
	ИначеЕсли ТипЗначения = Тип("Структура") Тогда
		
		Строки = Новый Массив;
		
		Если Уровень = 0 Тогда
			
			Строки.Добавить("Тип: Структура");
			Строки.Добавить("");
			
		КонецЕсли;
		
		Если Значение.Количество() = 0 Тогда
			
			Строки.Добавить(Префикс + "<пусто>");
			
		Иначе
			
			Для Каждого КлючИЗначение Из Значение Цикл
				
				Строки.Добавить(Префикс + КлючИЗначение.Ключ + " = "
					+ ПредставлениеЭлементаКоллекции(КлючИЗначение.Значение, Уровень));
				
			КонецЦикла;
			
		КонецЕсли;
		
		Возврат СтрСоединить(Строки, Символы.ПС);
		
	ИначеЕсли ТипЗначения = Тип("Соответствие") Тогда
		
		Строки = Новый Массив;
		
		Если Уровень = 0 Тогда
			
			Строки.Добавить("Тип: Соответствие");
			Строки.Добавить("");
			
		КонецЕсли;
		
		Если Значение.Количество() = 0 Тогда
			
			Строки.Добавить(Префикс + "<пусто>");
			
		Иначе
			
			Для Каждого КлючИЗначение Из Значение Цикл
				
				Строки.Добавить(Префикс + Строка(КлючИЗначение.Ключ) + " = "
					+ ПредставлениеЭлементаКоллекции(КлючИЗначение.Значение, Уровень));
				
			КонецЦикла;
			
		КонецЕсли;
		
		Возврат СтрСоединить(Строки, Символы.ПС);
		
	ИначеЕсли ТипЗначения = Тип("Массив") Тогда
		
		Строки = Новый Массив;
		
		Если Уровень = 0 Тогда
			
			Строки.Добавить("Тип: Массив (" + Формат(Значение.Количество(), "ЧГ=0") + ")");
			Строки.Добавить("");
			
		КонецЕсли;
		
		Если Значение.Количество() = 0 Тогда
			
			Строки.Добавить(Префикс + "<пусто>");
			
		Иначе
			
			Индекс = 0;
			
			Для Каждого ЭлементМассива Из Значение Цикл
				
				Строки.Добавить(Префикс + "[" + Формат(Индекс, "ЧН=0; ЧГ=0") + "] = "
					+ ПредставлениеЭлементаКоллекции(ЭлементМассива, Уровень));
				Индекс = Индекс + 1;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Возврат СтрСоединить(Строки, Символы.ПС);
		
	ИначеЕсли ТипЗначения = Тип("Строка") Тогда
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: Строка" + Символы.ПС + Символы.ПС + Значение;
			
		КонецЕсли;
		
		Возврат """" + Значение + """";
		
	ИначеЕсли ТипЗначения = Тип("Число") Тогда
		
		ТекстЧисла = Формат(Значение, "ЧН=0; ЧГ=0");
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: Число" + Символы.ПС + Символы.ПС + ТекстЧисла;
			
		КонецЕсли;
		
		Возврат ТекстЧисла;
		
	ИначеЕсли ТипЗначения = Тип("Булево") Тогда
		
		ТекстБулево = Формат(Значение, "БЛ=Ложь; БИ=Истина");
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: Булево" + Символы.ПС + Символы.ПС + ТекстБулево;
			
		КонецЕсли;
		
		Возврат ТекстБулево;
		
	ИначеЕсли ТипЗначения = Тип("Дата") Тогда
		
		ТекстДаты = Формат(Значение, "ДЛФ=DT");
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: Дата" + Символы.ПС + Символы.ПС + ТекстДаты;
			
		КонецЕсли;
		
		Возврат ТекстДаты;
		
	Иначе
		
		ТекстТипа = Строка(ТипЗначения);
		ТекстЗначения = ЗначениеВСтрокуВнутр(Значение);
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: " + ТекстТипа + Символы.ПС + Символы.ПС + ТекстЗначения;
			
		КонецЕсли;
		
		Возврат ТекстЗначения;
		
	КонецЕсли;
	
КонецФункции

// Возвращает краткое или развёрнутое представление элемента коллекции.
//
// Параметры:
//  ЗначениеЭлемента - Произвольный - значение элемента;
//  УровеньРодителя - Число - уровень родителя.
//
// Возвращаемое значение:
//  Строка - представление элемента.
//
Функция ПредставлениеЭлементаКоллекции(ЗначениеЭлемента, УровеньРодителя)
	
	ТипЗначения = ТипЗнч(ЗначениеЭлемента);
	
	Если ТипЗначения = Тип("Структура")
		Или ТипЗначения = Тип("Соответствие")
		Или ТипЗначения = Тип("Массив") Тогда
		
		Возврат Символы.ПС + СформироватьПредставлениеЗначения(ЗначениеЭлемента, УровеньРодителя + 1);
		
	КонецЕсли;
	
	Возврат СформироватьПредставлениеЗначения(ЗначениеЭлемента, УровеньРодителя + 1);
	
КонецФункции