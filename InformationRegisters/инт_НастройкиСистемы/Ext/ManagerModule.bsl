///////////////////////////////////////////////////////////////////////////////////////////////////////
// Модуль менеджера регистра сведений инт_НастройкиСистемы.
// Программный интерфейс чтения и записи настроек системы.
// Методы выполняются в привилегированном режиме — для административного доступа к настройкам.
///////////////////////////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Записывает настройку в регистр сведений.
//
// Параметры:
//  СтруктураНастройки - Структура - имена ключей совпадают с полями регистра;
//                                   обязателен ключ РазделНастроек.
//
// Возвращаемое значение:
//  Структура:
//    * Успех - Булево - Истина при успешной записи;
//    * ОписаниеОшибки - Строка - текст ошибки, если Успех = Ложь.
//
Функция ЗаписатьНастройкуСистемы(СтруктураНастройки) Экспорт
	
	РезультатЗаписи = Новый Структура("Успех, ОписаниеОшибки", Ложь, "");
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		
		Запись = РегистрыСведений.инт_НастройкиСистемы.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, СтруктураНастройки);
		Запись.Записать();
		РезультатЗаписи.Успех = Истина;
		
	Исключение
		
		РезультатЗаписи.ОписаниеОшибки = КраткоеПредставлениеОшибки(ИнформацияОбОшибке());
		
	КонецПопытки;
	
	Возврат РезультатЗаписи;
	
КонецФункции

// Получает значения настройки из записи регистра.
//
// Параметры:
//  ПараметрыПолучения - Структура:
//    * РазделНастроек - Строка, СправочникСсылка.инт_РазделНастроек - имя или ссылка раздела;
//    * ПолучитьЗначение - Булево - вернуть ресурс Значение;
//    * ПолучитьЗначениеХранилище - Булево - вернуть извлечённое значение из ЗначениеХранилище;
//    * ПолучитьЗначениеСтрокаНеограниченная - Булево - вернуть ресурс ЗначениеСтрокаНеограниченная;
//    * ПреобразоватьИзСтрокиВнутрСтрокаНеограниченная - Булево - разобрать длинную строку через ЗначениеИзСтрокиВнутр.
//
// Возвращаемое значение:
//  Произвольный - значение запрошенного ресурса, если запрошен один ресурс;
//  Структура - если запрошено несколько ресурсов;
//  Неопределено - ошибка параметров, раздел не найден или запись отсутствует.
//
Функция ПолучитьНастройкуСистемы(ПараметрыПолучения) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Не ПараметрыПолучения.Свойство("РазделНастроек") Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	Если ТипЗнч(ПараметрыПолучения.РазделНастроек) = Тип("Строка") Тогда
		
		РазделНастроекСсылка = ПолучитьРазделНастроекПоИмени(ПараметрыПолучения.РазделНастроек);
		
	Иначе
		
		РазделНастроекСсылка = ПараметрыПолучения.РазделНастроек;
		
	КонецЕсли;
	
	Если ТипЗнч(РазделНастроекСсылка) <> Тип("СправочникСсылка.инт_РазделНастроек") Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	ПолучитьЗначение = ПараметрыПолучения.Свойство("ПолучитьЗначение") И ПараметрыПолучения.ПолучитьЗначение;
	ПолучитьХранилище = ПараметрыПолучения.Свойство("ПолучитьЗначениеХранилище") И ПараметрыПолучения.ПолучитьЗначениеХранилище;
	ПолучитьДлиннуюСтроку = ПараметрыПолучения.Свойство("ПолучитьЗначениеСтрокаНеограниченная")
		И ПараметрыПолучения.ПолучитьЗначениеСтрокаНеограниченная;
	
	КоличествоРесурсов = Число(ПолучитьЗначение) + Число(ПолучитьХранилище) + Число(ПолучитьДлиннуюСтроку);
	
	Если КоличествоРесурсов = 0 Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	ПоляВыборки = Новый Массив;
	
	Если ПолучитьЗначение Тогда
		
		ПоляВыборки.Добавить("РС.Значение КАК Значение");
		
	КонецЕсли;
	
	Если ПолучитьХранилище Тогда
		
		ПоляВыборки.Добавить("РС.ЗначениеХранилище КАК ЗначениеХранилище");
		
	КонецЕсли;
	
	Если ПолучитьДлиннуюСтроку Тогда
		
		ПоляВыборки.Добавить("РС.ЗначениеСтрокаНеограниченная КАК ЗначениеСтрокаНеограниченная");
		
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	" + СтрСоединить(ПоляВыборки, "," + Символы.ПС + "	") + "
	|ИЗ
	|	РегистрСведений.инт_НастройкиСистемы КАК РС
	|ГДЕ
	|	РС.РазделНастроек = &РазделНастроек";
	Запрос.УстановитьПараметр("РазделНастроек", РазделНастроекСсылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		
		Возврат Неопределено;
		
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	Если КоличествоРесурсов = 1 Тогда
		
		Если ПолучитьЗначение Тогда
			
			Возврат Выборка.Значение;
			
		ИначеЕсли ПолучитьХранилище Тогда
			
			Возврат ИзвлечьЗначениеИзХранилища(Выборка.ЗначениеХранилище);
			
		Иначе
			
			Возврат ОбработатьДлиннуюСтроку(Выборка.ЗначениеСтрокаНеограниченная, ПараметрыПолучения);
			
		КонецЕсли;
		
	КонецЕсли;
	
	РезультатСтруктура = Новый Структура;
	
	Если ПолучитьЗначение Тогда
		
		РезультатСтруктура.Вставить("Значение", Выборка.Значение);
		
	КонецЕсли;
	
	Если ПолучитьХранилище Тогда
		
		РезультатСтруктура.Вставить("ЗначениеХранилище", ИзвлечьЗначениеИзХранилища(Выборка.ЗначениеХранилище));
		
	КонецЕсли;
	
	Если ПолучитьДлиннуюСтроку Тогда
		
		РезультатСтруктура.Вставить("ЗначениеСтрокаНеограниченная",
			ОбработатьДлиннуюСтроку(Выборка.ЗначениеСтрокаНеограниченная, ПараметрыПолучения));
		
	КонецЕсли;
	
	Возврат РезультатСтруктура;
	
КонецФункции

// Возвращает ссылку на элемент справочника инт_РазделНастроек по наименованию.
//
// Параметры:
//  Имя - Строка - наименование для поиска;
//  Наименование - Строка - наименование при создании нового элемента (если пусто — используется Имя);
//  СоздатьНовый - Булево - создать элемент, если не найден.
//
// Возвращаемое значение:
//  СправочникСсылка.инт_РазделНастроек - найденная, созданная или пустая ссылка.
//
Функция ПолучитьРазделНастроекПоИмени(Имя, Наименование = "", СоздатьНовый = Ложь) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если Не ЗначениеЗаполнено(Имя) Или ТипЗнч(Имя) <> Тип("Строка") Тогда
		
		Возврат Справочники.инт_РазделНастроек.ПустаяСсылка();
		
	КонецЕсли;
	
	РазделНастроекСсылка = Справочники.инт_РазделНастроек.НайтиПоНаименованию(Имя, Истина);
	
	Если ЗначениеЗаполнено(РазделНастроекСсылка) Или Не СоздатьНовый Тогда
		
		Возврат РазделНастроекСсылка;
		
	КонецЕсли;
	
	СпрОбъект = Справочники.инт_РазделНастроек.СоздатьЭлемент();
	СпрОбъект.Наименование = ?(ЗначениеЗаполнено(Наименование), Наименование, Имя);
	СпрОбъект.Записать();
	
	Возврат СпрОбъект.Ссылка;
	
КонецФункции

// Проверяет, есть ли в записи непустое значение ресурса ЗначениеХранилище.
//
// Параметры:
//  РазделНастроек - СправочникСсылка.инт_РазделНастроек - раздел настроек.
//
// Возвращаемое значение:
//  Булево - Истина, если в хранилище есть извлечённое значение.
//
Функция ЕстьСодержимоеХранилища(РазделНастроек) Экспорт
	
	Если Не ЗначениеЗаполнено(РазделНастроек) Тогда
		
		Возврат Ложь;
		
	КонецЕсли;
	
	ПараметрыПолучения = Новый Структура;
	ПараметрыПолучения.Вставить("РазделНастроек", РазделНастроек);
	ПараметрыПолучения.Вставить("ПолучитьЗначениеХранилище", Истина);
	
	ЗначениеИзХранилища = ПолучитьНастройкуСистемы(ПараметрыПолучения);
	
	Возврат ЗначениеИзХранилища <> Неопределено;
	
КонецФункции

// Формирует текстовое представление содержимого хранилища значений настройки.
//
// Параметры:
//  РазделНастроек - СправочникСсылка.инт_РазделНастроек - раздел настроек.
//
// Возвращаемое значение:
//  Структура:
//    * Успех - Булево - удалось ли получить содержимое;
//    * Текст - Строка - представление или сообщение об ошибке;
//    * Заголовок - Строка - заголовок окна просмотра.
//
Функция ПолучитьТекстСодержимогоХранилища(РазделНастроек) Экспорт
	
	Результат = Новый Структура("Успех, Текст, Заголовок", Ложь, "", "");
	
	Если Не ЗначениеЗаполнено(РазделНастроек) Тогда
		
		Результат.Текст = "Не указан раздел настроек.";
		Возврат Результат;
		
	КонецЕсли;
	
	ПараметрыПолучения = Новый Структура;
	ПараметрыПолучения.Вставить("РазделНастроек", РазделНастроек);
	ПараметрыПолучения.Вставить("ПолучитьЗначение", Истина);
	ПараметрыПолучения.Вставить("ПолучитьЗначениеХранилище", Истина);
	
	ДанныеНастройки = ПолучитьНастройкуСистемы(ПараметрыПолучения);
	
	Если ДанныеНастройки = Неопределено Тогда
		
		Результат.Текст = "Запись настройки не найдена.";
		Возврат Результат;
		
	КонецЕсли;
	
	Если ДанныеНастройки.ЗначениеХранилище = Неопределено Тогда
		
		Результат.Текст = "В хранилище значений нет данных.";
		Возврат Результат;
		
	КонецЕсли;
	
	Результат.Успех = Истина;
	Результат.Заголовок = "Содержимое настройки: " + Строка(РазделНастроек);
	Результат.Текст = СформироватьПредставлениеЗначения(ДанныеНастройки.ЗначениеХранилище);
	
	Возврат Результат;
	
КонецФункции

// Строит читаемое текстовое представление произвольного значения.
//
// Параметры:
//  Значение - Произвольный - значение из хранилища;
//  Уровень - Число - уровень вложенности для отступа.
//
// Возвращаемое значение:
//  Строка - текстовое представление.
//
Функция СформироватьПредставлениеЗначения(Значение, Уровень = 0) Экспорт
	
	Префикс = "";
	
	Для Счетчик = 1 По Уровень Цикл
		
		Префикс = Префикс + "  ";
		
	КонецЦикла;
	
	ТипЗначения = ТипЗнч(Значение);
	
	Если Значение = Неопределено Тогда
		
		Возврат Префикс + "<Неопределено>";
		
	ИначеЕсли ТипЗначения = Тип("Структура") Тогда
		
		Строки = Новый Массив;
		
		Если Уровень = 0 Тогда
			
			Строки.Добавить("Тип: Структура");
			Строки.Добавить("");
			
		КонецЕсли;
		
		Если Значение.Количество() = 0 Тогда
			
			Строки.Добавить(Префикс + "<пусто>");
			
		Иначе
			
			Для Каждого КлючИЗначение Из Значение Цикл
				
				Строки.Добавить(Префикс + КлючИЗначение.Ключ + " = "
					+ ПредставлениеЭлементаКоллекции(КлючИЗначение.Значение, Уровень));
				
			КонецЦикла;
			
		КонецЕсли;
		
		Возврат СтрСоединить(Строки, Символы.ПС);
		
	ИначеЕсли ТипЗначения = Тип("Соответствие") Тогда
		
		Строки = Новый Массив;
		
		Если Уровень = 0 Тогда
			
			Строки.Добавить("Тип: Соответствие");
			Строки.Добавить("");
			
		КонецЕсли;
		
		Если Значение.Количество() = 0 Тогда
			
			Строки.Добавить(Префикс + "<пусто>");
			
		Иначе
			
			Для Каждого КлючИЗначение Из Значение Цикл
				
				Строки.Добавить(Префикс + Строка(КлючИЗначение.Ключ) + " = "
					+ ПредставлениеЭлементаКоллекции(КлючИЗначение.Значение, Уровень));
				
			КонецЦикла;
			
		КонецЕсли;
		
		Возврат СтрСоединить(Строки, Символы.ПС);
		
	ИначеЕсли ТипЗначения = Тип("Массив") Тогда
		
		Строки = Новый Массив;
		
		Если Уровень = 0 Тогда
			
			Строки.Добавить("Тип: Массив (" + Формат(Значение.Количество(), "ЧГ=0") + ")");
			Строки.Добавить("");
			
		КонецЕсли;
		
		Если Значение.Количество() = 0 Тогда
			
			Строки.Добавить(Префикс + "<пусто>");
			
		Иначе
			
			Индекс = 0;
			
			Для Каждого ЭлементМассива Из Значение Цикл
				
				Строки.Добавить(Префикс + "[" + Формат(Индекс, "ЧН=0; ЧГ=0") + "] = "
					+ ПредставлениеЭлементаКоллекции(ЭлементМассива, Уровень));
				Индекс = Индекс + 1;
				
			КонецЦикла;
			
		КонецЕсли;
		
		Возврат СтрСоединить(Строки, Символы.ПС);
		
	ИначеЕсли ТипЗначения = Тип("Строка") Тогда
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: Строка" + Символы.ПС + Символы.ПС + Значение;
			
		КонецЕсли;
		
		Возврат """" + Значение + """";
		
	ИначеЕсли ТипЗначения = Тип("Число") Тогда
		
		ТекстЧисла = Формат(Значение, "ЧН=0; ЧГ=0");
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: Число" + Символы.ПС + Символы.ПС + ТекстЧисла;
			
		КонецЕсли;
		
		Возврат ТекстЧисла;
		
	ИначеЕсли ТипЗначения = Тип("Булево") Тогда
		
		ТекстБулево = Формат(Значение, "БЛ=Ложь; БИ=Истина");
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: Булево" + Символы.ПС + Символы.ПС + ТекстБулево;
			
		КонецЕсли;
		
		Возврат ТекстБулево;
		
	ИначеЕсли ТипЗначения = Тип("Дата") Тогда
		
		ТекстДаты = Формат(Значение, "ДЛФ=DT");
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: Дата" + Символы.ПС + Символы.ПС + ТекстДаты;
			
		КонецЕсли;
		
		Возврат ТекстДаты;
		
	Иначе
		
		ТекстТипа = Строка(ТипЗначения);
		ТекстЗначения = ЗначениеВСтрокуВнутр(Значение);
		
		Если Уровень = 0 Тогда
			
			Возврат "Тип: " + ТекстТипа + Символы.ПС + Символы.ПС + ТекстЗначения;
			
		КонецЕсли;
		
		Возврат ТекстЗначения;
		
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Извлекает значение из хранилища значений.
//
// Параметры:
//  ЗначениеХранилище - ХранилищеЗначения, Произвольный - ресурс регистра.
//
// Возвращаемое значение:
//  Произвольный - извлечённое значение или Неопределено.
//
Функция ИзвлечьЗначениеИзХранилища(ЗначениеХранилище)
	
	Если ТипЗнч(ЗначениеХранилище) = Тип("ХранилищеЗначения") Тогда
		
		Возврат ЗначениеХранилище.Получить();
		
	КонецЕсли;
	
	Возврат ЗначениеХранилище;
	
КонецФункции

// При необходимости преобразует длинную строку через ЗначениеИзСтрокиВнутр.
//
// Параметры:
//  ЗначениеСтроки - Строка - ресурс регистра;
//  ПараметрыПолучения - Структура - параметры вызова ПолучитьНастройкуСистемы.
//
// Возвращаемое значение:
//  Произвольный - исходная строка или разобранное значение.
//
Функция ОбработатьДлиннуюСтроку(ЗначениеСтроки, ПараметрыПолучения)
	
	ПреобразоватьИзСтрокиВнутр = ПараметрыПолучения.Свойство("ПреобразоватьИзСтрокиВнутрСтрокаНеограниченная")
		И ПараметрыПолучения.ПреобразоватьИзСтрокиВнутрСтрокаНеограниченная;
	
	Если Не ПреобразоватьИзСтрокиВнутр Тогда
		
		Возврат ЗначениеСтроки;
		
	КонецЕсли;
	
	Попытка
		
		Возврат ЗначениеИзСтрокиВнутр(ЗначениеСтроки);
		
	Исключение
		
		Возврат ЗначениеСтроки;
		
	КонецПопытки;
	
КонецФункции

// Возвращает представление элемента коллекции с учётом вложенности.
//
// Параметры:
//  ЗначениеЭлемента - Произвольный - значение элемента;
//  УровеньРодителя - Число - уровень родителя.
//
// Возвращаемое значение:
//  Строка - представление элемента.
//
Функция ПредставлениеЭлементаКоллекции(ЗначениеЭлемента, УровеньРодителя)
	
	ТипЗначения = ТипЗнч(ЗначениеЭлемента);
	
	Если ТипЗначения = Тип("Структура")
		Или ТипЗначения = Тип("Соответствие")
		Или ТипЗначения = Тип("Массив") Тогда
		
		Возврат Символы.ПС + СформироватьПредставлениеЗначения(ЗначениеЭлемента, УровеньРодителя + 1);
		
	КонецЕсли;
	
	Возврат СформироватьПредставлениеЗначения(ЗначениеЭлемента, УровеньРодителя + 1);
	
КонецФункции

